{
  "name": "d20-folio-functions",
  "version": "0.1.0",
  "description": "Cloud Functions for d20 Folio — bug-report → GitHub issue (OWN-37) and new-user signup email (OWN-38).",
  "private": true,
  "type": "commonjs",
  "main": "lib/index.js",
  "engines": {
    "node": "24"
  },
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "lint": "eslint .",
    "test": "vitest run",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "deploy": "firebase deploy --only functions"
  },
  "dependencies": {
    "@google-cloud/billing": "^5.1.2",
    "@google-cloud/functions-framework": "^5.0.2",
    "@octokit/rest": "^22.0.1",
    "firebase-admin": "^13.10.0",
    "firebase-functions": "^7.2.5",
    "nodemailer": "^9.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/nodemailer": "^8.0.0",
    "eslint": "^10.4.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "form-data@<2.5.6": "2.5.6",
    "protobufjs@<7.6.5": "7.6.5",
    "uuid@<11.1.1": "11.1.1",
    "brace-expansion@>=3.0.0 <5.0.7": "5.0.7",
    "body-parser@<1.20.6": "1.20.6",
    "body-parser@>=2.0.0 <2.3.0": "2.3.0"
  }
}
