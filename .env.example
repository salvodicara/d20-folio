# Firebase Configuration
# Get these from Firebase Console → Project Settings → Your apps → Web app
VITE_FIREBASE_API_KEY=your-api-key
VITE_FIREBASE_AUTH_DOMAIN=d20-folio.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=d20-folio
VITE_FIREBASE_STORAGE_BUCKET=d20-folio.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Set to "true" to use Firebase emulators for local development
VITE_USE_EMULATORS=false

# Set to "true" to bypass auth and load mock data (UI dev without Firebase)
VITE_DEV_BYPASS_AUTH=false
