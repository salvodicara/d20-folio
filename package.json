{
  "name": "d20-folio",
  "private": true,
  "version": "0.20.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/salvodicara/d20-folio.git"
  },
  "homepage": "https://d20-folio.web.app",
  "bugs": "https://github.com/salvodicara/d20-folio/issues",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "scripts": {
    "dev": "vite",
    "dev:emulators": "VITE_USE_EMULATORS=true vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --cache",
    "i18n:check": "node scripts/i18n/check-i18n.ts",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"content-pack/**/*.{ts,tsx,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"content-pack/**/*.{ts,tsx,json}\"",
    "test": "vitest run --project fast --project slow",
    "test:budget": "vitest run --project budget",
    "test:fast": "vitest run --project fast",
    "test:slow": "vitest run --project slow",
    "test:watch": "vitest",
    "test:coverage": "vitest run --project fast --project slow --coverage",
    "test:srd-only": "VITE_CONTENT_PACK=0 vitest run --project fast --project slow",
    "typecheck:srd-only": "tsc -p tsconfig.srd-only.json",
    "build:srd-only": "pnpm typecheck:srd-only && VITE_CONTENT_PACK=0 vite build",
    "test:e2e": "playwright test --project=chromium",
    "test:e2e:visual": "VISUAL=1 playwright test --project=chromium visual",
    "test:e2e:all": "playwright test",
    "test:e2e:all:visual": "VISUAL=1 playwright test visual",
    "test:rules": "firebase emulators:exec --only firestore,storage --project demo-d20folio 'pnpm exec vitest run --config vitest.rules.config.ts'",
    "typecheck": "tsc -b",
    "changeset": "changeset",
    "changeset:status": "changeset status",
    "changeset:version": "changeset version && pnpm install --lockfile-only",
    "changeset:tag": "changeset tag"
  },
  "dependencies": {
    "@fontsource-variable/alegreya": "^5.2.8",
    "@fontsource-variable/cinzel": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@pdf-lib/fontkit": "^1.1.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fflate": "^0.8.3",
    "firebase": "^12.13.0",
    "html2canvas-pro": "^2.0.4",
    "i18next": "^26.2.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "pdf-lib": "^1.17.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-easy-crop": "^5.5.7",
    "react-i18next": "^17.0.8",
    "react-router": "^7.15.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.7",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "firebase-admin": "^14.0.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --max-warnings 0 --no-warn-ignored"
    ],
    "*.{ts,tsx,css,json,md}": [
      "prettier --check"
    ]
  }
}
