rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the request from an authenticated user?
    function isAuth() {
      return request.auth != null;
    }

    // Helper: is the authenticated user not blocked?
    // Uses get() — only call this on paths where the user doc is guaranteed to exist
    // (i.e. after first sign-in completes). Do NOT use on the /users/{uid} path itself.
    function isNotBlocked() {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.status != "blocked";
    }

    // Helper: is the user an admin? DATA-DRIVEN — reads `role: "admin"` from the
    // requester's own user doc (the SAME field the client's `useIsAdmin` reads), so
    // client + rules can't drift and no uid is hardcoded. Granted out-of-band
    // (Firestore console / an admin script); never settable by the client (update
    // is admin-only, create forbids it — see below). Assumes the user doc exists
    // (same precondition as isNotBlocked); `data.get("role", "")` treats a doc
    // without the field as simply "not admin" rather than erroring.
    function isAdmin() {
      return isAuth()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get("role", "") == "admin";
    }

    // Users collection
    // - Read own doc: only auth required (no get() loop)
    // - Create own doc: first sign-in bootstrap — but MUST NOT self-assign the
    //   admin role (that's the self-promotion vector; admin is granted out-of-band)
    // - Update: ADMIN (full — block/unblock, grant role) OR the owner's OWN
    //   telemetry-only self-update (the recurring `lastActiveAt` sign-in bump in
    //   `src/lib/auth.ts`). A non-admin may touch ONLY their own `lastActiveAt` and
    //   NOTHING else — never `role` (the role-escalation vector) and never `status`
    //   (the self-UNBLOCK vector). The field-lock uses the SAME
    //   diff().affectedKeys().hasOnly() construct proven in the campaign rules. A
    //   non-admin still cannot touch ANOTHER user's doc (the request.auth.uid == uid
    //   guard). Before this, `update` was admin-only, so a normal user's recurring
    //   lastActiveAt write was silently DENIED (it only ever landed for admins) —
    //   this fixes that latent gap while keeping role/status admin-only.
    // - List: admin only
    match /users/{uid} {
      // A non-admin may update ONLY their own doc and ONLY the `lastActiveAt`
      // telemetry field — defined INSIDE the match so the `{uid}` wildcard is in
      // scope. Same diff().affectedKeys().hasOnly() construct proven in the
      // campaign rules.
      function isSelfTelemetryUpdate() {
        return request.auth.uid == uid
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["lastActiveAt"]);
      }
      allow read:   if isAuth() && (request.auth.uid == uid || isAdmin());
      allow create: if isAuth() && request.auth.uid == uid
        && request.resource.data.get("role", "") != "admin";
      allow update: if isAdmin() || isSelfTelemetryUpdate();
      allow list:   if isAdmin();
    }

    // Characters — users CRUD their own (blocked check applied here, user doc
    // exists by now). Admin can read all (for stats). A CO-MEMBER reads a peer's
    // REAL character doc THE SAME WAY the owner's cockpit does (ONE load path):
    // sheets are fully open to the team — every campaign member may READ every other
    // member's sheet (secrecy is DM-vs-players, never player-vs-player).
    //
    // CROSS-USER ACCESS IS DERIVED LIVE — THE SINGLE SOURCE OF TRUTH IS THE CAMPAIGN
    // DOC. The character carries ONE pointer, `attachedCampaignId` (written
    // ATOMICALLY with the campaign's `memberDetails` by the attach transaction —
    // `campaign-io.attachMemberCharacter`); the grant is "the requester is a CURRENT
    // member of THAT campaign", read live off the campaign doc here. There is NO
    // stored reader list to recompute or go stale (the old client-maintained
    // `dmReaders`/`campaignReaders` ACLs — whose convergence failures produced the
    // "DM access out of date" outages — are deleted). A DM transfer or roster change
    // is effective IMMEDIATELY (the next request reads the live campaign doc).
    // WRITE stays owner-only — neither a peer nor a DM ever writes a member's
    // character doc.
    match /users/{uid}/characters/{charId} {
      // The campaign this character claims attachment to. Only evaluated AFTER the
      // has-a-claim guard below; a dangling claim (campaign deleted) errors the
      // get() → the branch denies, which is the correct fail-closed behaviour.
      function attachedCampaign() {
        return get(/databases/$(database)/documents/campaigns/$(resource.data.attachedCampaignId)).data;
      }
      allow read:  if (isNotBlocked() && request.auth.uid == uid)
        || isAdmin()
        || (isNotBlocked()
            && resource.data.get("attachedCampaignId", "") != ""
            && request.auth.uid in attachedCampaign().members);
      allow write: if isNotBlocked() && request.auth.uid == uid;
    }

    // Per-character combat-state subdoc — the character's OWN combat-mutable state
    // (HP / conditions / death saves / the solo round + initiative roll) at
    // `…/combat/state`. READ and WRITE have DIFFERENT grants (read-superset /
    // write-subset), both DERIVED LIVE from the parent char's `attachedCampaignId`
    // pointer + the campaign doc (same model as the char-doc read above — no stored
    // ACL, nothing to go stale):
    //   - READ:  the OWNER, the admin, OR any CURRENT MEMBER of the attached
    //     campaign (every campaign peer may watch a teammate's live combat state).
    //   - WRITE: the OWNER, the admin, OR the attached campaign's CURRENT DM
    //     (`dmUid`) — a co-member may READ a peer's combat but NOT write it.
    // The OR is ordered so the cheap owner check short-circuits BEFORE any get();
    // a cross-user request costs at most two extra gets (parent char + campaign,
    // deduped per request), well under the 10-get cap.
    //
    // NO shape validation, DELIBERATELY. The old field-locked isValidCombatState()
    // (`keys().hasOnly([...])`) rejected EVERY combat write whenever the DEPLOYED
    // rules lagged the client's payload by a single field — the "initiative never
    // saves" production outage (new client wrote `round`; prod rules didn't allow
    // the key yet) — and every writer here is already trusted (owner / admin / the
    // campaign's own DM) while the client parses the doc DEFENSIVELY on read
    // (`combat-state-io.parseCombatState`). The lock bought no real safety and
    // carried a standing whole-feature outage class; authorization is the rule's
    // job, shape tolerance is the client's.
    match /users/{uid}/characters/{charId}/combat/{stateId} {
      function parentChar() {
        return get(/databases/$(database)/documents/users/$(uid)/characters/$(charId)).data;
      }
      function parentCampaign() {
        return get(/databases/$(database)/documents/campaigns/$(parentChar().attachedCampaignId)).data;
      }
      function hasAttachedCampaign() {
        return parentChar().get("attachedCampaignId", "") != "";
      }
      allow read: if isNotBlocked() && (
        request.auth.uid == uid
        || isAdmin()
        || (hasAttachedCampaign() && request.auth.uid in parentCampaign().members)
      );
      allow write: if isNotBlocked() && (
        request.auth.uid == uid
        || isAdmin()
        || (hasAttachedCampaign() && request.auth.uid == parentCampaign().dmUid)
      );
    }

    // Character snapshots
    match /users/{uid}/characters/{charId}/snapshots/{snapId} {
      allow read, write: if isNotBlocked() && request.auth.uid == uid;
    }

    // Campaigns — the enforced access matrix is exercised by
    // tests/rules/firestore-rules.test.ts (member/non-member/blocked/admin/A13/
    // list-scoped/subcollection/member-mutation). Free-tier: one doc per campaign.
    match /campaigns/{campId} {
      function isMember() {
        return isNotBlocked() && request.auth.uid in resource.data.members;
      }
      function isDm() {
        return isNotBlocked() && request.auth.uid == resource.data.dmUid;
      }

      // A regular member's update may edit shared artifacts (treasury, notes,
      // name, status) but MUST NOT change the roster or ownership.
      function rosterAndOwnerUnchanged() {
        return request.resource.data.members == resource.data.members
          && request.resource.data.memberDetails.keys().toSet()
               == resource.data.memberDetails.keys().toSet()
          && request.resource.data.dmUid == resource.data.dmUid
          && request.resource.data.createdBy == resource.data.createdBy;
      }

      // A regular member may change AT MOST their OWN memberDetails entry — never
      // another member's (the "A-edits-B" vector: rosterAndOwnerUnchanged only pins
      // the KEY SET, not which value changed, so without this a member could
      // overwrite a peer's characterId / character / role). diff().affectedKeys() at
      // the map level is the set of member uids whose VALUE changed: a self-attach
      // (setMemberCharacter) touches only the caller's uid; a shared-artifact edit
      // (treasury/notes/name/banner) touches NO memberDetails value → empty set,
      // which hasOnly() accepts. Same affectedKeys() construct proven in isSelfJoin().
      function memberEditsOnlyOwnEntry() {
        return request.resource.data.memberDetails
          .diff(resource.data.memberDetails)
          .affectedKeys()
          .hasOnly([request.auth.uid]);
      }

      // The encounter STRUCTURE is a DM tool — a regular member may NOT mutate it (it
      // touches neither the roster nor memberDetails, so the guards above would
      // otherwise let a member write it). get(...,null) so a doc WITHOUT the field
      // (the existing fixtures / pre-feature docs) still validates on both sides.
      function encounterUnchanged() {
        return request.resource.data.get('encounter', null)
          == resource.data.get('encounter', null);
      }

      // P2 — the TURN POINTER is shared: any member may advance it (the player whose PC
      // is current, or the DM), so a member's update is also allowed when the encounter
      // diff touches ONLY the two turn fields (currentCombatantId + round) — the
      // combatants array / status / membership stay byte-identical. The encounter must
      // EXIST on both sides (a member can't add/remove the encounter, only move the
      // pointer). Rules CANNOT iterate the combatants array to prove the writer IS the
      // current combatant, so this grant is intentionally coarse (any member may move
      // the pointer) and the strict who-is-current check stays UI-side — DM-correctable,
      // low-risk, per the owner mandate. Same diff().affectedKeys().hasOnly() construct
      // proven in memberEditsOnlyOwnEntry() / isSelfJoin().
      //
      // C3 — the FROZEN turn order (`encounter.order`) is DM-ONLY STRUCTURAL state: it is
      // deliberately NOT in this allow-set, so a regular member advancing the turn can
      // never freeze, drag-reorder, or otherwise rewrite the order (a diff that touches
      // `order` fails hasOnly() → the member branch denies it). Begin-turns + drag-reorder
      // therefore stay DM/admin-only by construction (the unconstrained isDm()/isAdmin()
      // update branch writes the whole encounter, `order` included) — no new write path,
      // no loosening. Pinned by the "frozen order is DM-only" rules tests.
      function turnFieldsOnlyChanged() {
        return resource.data.get('encounter', null) != null
          && request.resource.data.get('encounter', null) != null
          && request.resource.data.encounter.diff(resource.data.encounter)
               .affectedKeys().hasOnly(['currentCombatantId', 'round']);
      }

      // INIT-SSOT — the `encounterInit` initiative table (`uid → raw d20 roll`, the
      // SIBLING of `encounter`) is the ONE home of PC initiative, and it is
      // DUAL-WRITER by design (the owner's mandate: "both should be able to edit
      // the initiative"): the DM/admin writes ANY row via the unconstrained
      // isDm()/isAdmin() branch below; a regular member may change AT MOST their
      // OWN row — the diff over the table touches only their uid (add / re-roll /
      // clear all pass; touching a peer's row fails hasOnly()). get(..., {}) so a
      // doc WITHOUT the table (pre-feature docs) validates on both sides, and a
      // shared-artifact edit that doesn't touch the table diffs to the empty set,
      // which hasOnly() accepts. Same map-diff construct proven in
      // memberEditsOnlyOwnEntry() / isSelfJoin().
      function encounterInitOwnEntryOnly() {
        return request.resource.data.get('encounterInit', {})
          .diff(resource.data.get('encounterInit', {}))
          .affectedKeys().hasOnly([request.auth.uid]);
      }

      // joinsLocked is a DM tool (the invite kill switch) — a regular member must
      // NOT flip it (it's neither roster nor memberDetails, so the guards above
      // would otherwise let a member toggle it). get(...,false) so a doc WITHOUT the
      // field (existing fixtures / pre-feature docs) validates on both sides.
      function joinsLockedUnchanged() {
        return request.resource.data.get('joinsLocked', false)
          == resource.data.get('joinsLocked', false);
      }

      // Controlled self-join: a non-member adds ONLY their own uid + their own
      // memberDetails entry, and changes nothing else. The campaign doc id == its
      // invite code, so a joiner resolves it from the code with no read access.
      // A locked campaign (joinsLocked == true) refuses ALL self-joins — the
      // no-migration kill switch for a leaked invite link. get(...,false) so a doc
      // WITHOUT the field (existing fixtures / pre-feature docs) reads as "open". A
      // non-member also must not flip the flag, so it stays UNCHANGED here; only the
      // DM toggles it (the unconstrained isDm() update branch).
      function isSelfJoin() {
        return isNotBlocked()
          && resource.data.get('joinsLocked', false) != true
          && !(request.auth.uid in resource.data.members)
          && request.resource.data.members.toSet()
               == resource.data.members.toSet().union([request.auth.uid].toSet())
          && request.resource.data.memberDetails.diff(resource.data.memberDetails)
               .affectedKeys() == [request.auth.uid].toSet()
          && request.resource.data.dmUid == resource.data.dmUid
          && request.resource.data.createdBy == resource.data.createdBy
          && request.resource.data.inviteCode == resource.data.inviteCode
          && request.resource.data.treasury == resource.data.treasury
          && request.resource.data.treasuryLog == resource.data.treasuryLog
          && request.resource.data.status == resource.data.status
          && request.resource.data.get('joinsLocked', false)
               == resource.data.get('joinsLocked', false)
          && request.resource.data.name == resource.data.name;
      }

      // Read one campaign: members only (admin override for stats).
      allow get: if isMember() || isAdmin();
      // List: ONLY a membership-scoped query (where members array-contains uid)
      // satisfies this rule, so an unconstrained list that could surface other
      // players' campaigns is denied. Admin may enumerate (stats).
      allow list: if isAdmin()
        || (isNotBlocked() && request.auth.uid in resource.data.members);

      // A13 — creator must be a member, be recorded as createdBy, AND be the DM.
      // Without this a user could create a campaign they're locked out of, or
      // impersonate another user as creator/DM.
      allow create: if isNotBlocked()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.dmUid == request.auth.uid;

      // A member edits shared artifacts (roster + encounter frozen) AND only their
      // own member entry; the DM manages the roster + the encounter tracker; the
      // admin may write any DM-tool field; a non-member may self-join. Only the DM
      // may delete the campaign.
      allow update: if (isMember() && rosterAndOwnerUnchanged() && memberEditsOnlyOwnEntry() && (encounterUnchanged() || turnFieldsOnlyChanged()) && encounterInitOwnEntryOnly() && joinsLockedUnchanged())
        || isDm()
        || isAdmin()
        || isSelfJoin();
      allow delete: if isDm();
    }

    // HIDDEN shared notes — the content-sharing SOFT-REVEAL gate, enforced by the
    // COLLECTION PATH (not a document field). A note staged hidden lives in
    // `dmNotes`, readable/writable by the DM/admin ONLY; revealing it MOVES it to the
    // members-readable `notes` collection. Path-based is the only LIST-safe gate:
    // Firestore rules are not filters, so a content-based read rule
    // (`resource.data.dmOnly != true`) would still let a member's UNSCOPED list
    // return the hidden docs — a member simply cannot read or list `dmNotes` at all.
    // A member therefore can neither read a hidden note nor author/hide one (writing
    // `dmNotes` is DM-only); the DM reveals/hides by moving the doc between the two.
    match /campaigns/{campId}/dmNotes/{noteId} {
      function dmNotesDm() {
        return isNotBlocked()
          && request.auth.uid == get(/databases/$(database)/documents/campaigns/$(campId)).data.dmUid;
      }
      allow read, write: if isAdmin() || dmNotesDm();
    }

    // Campaign subcollections (chronicle, sessions, the REVEALED `notes`) — members
    // of the parent only. (The DM "View Sheet" feature reads the member's real
    // character doc via the `dmReaders` ACL above — there is no longer a denormalized
    // full-sheet copy subcollection to gate here.) EXCLUDES `dmNotes`: those are the
    // hidden-note collection gated DM-only ABOVE, and Firestore OR-combines matching
    // rules, so without this exclusion the broad member grant here would defeat the
    // hidden-note gate (a player could read a staged-hidden note through it).
    match /campaigns/{campId}/{subcol}/{docId} {
      allow read, write: if subcol != 'dmNotes' && isNotBlocked()
        && request.auth.uid in get(/databases/$(database)/documents/campaigns/$(campId)).data.members;
    }

    // Shared characters (public read-only links)
    match /shared/{shareId} {
      allow read:          if true; // Public — anyone with the link
      allow create:        if isNotBlocked() && request.resource.data.ownerUid == request.auth.uid;
      allow update, delete: if isNotBlocked() && request.auth.uid == resource.data.ownerUid;
    }

    // Bug / feature reports (OWN-37). A signed-in, non-blocked user CREATES a
    // report shaped for the onCreate Cloud Function (which runs with the Admin
    // SDK and bypasses these rules to write the issueNumber back). Reports carry a
    // debug context, so only the admin may READ them; no client may update/delete
    // — only the function does (admin SDK), on write-back.
    match /bug_reports/{id} {
      allow read:           if isAdmin();
      allow create:         if isNotBlocked()
        && request.resource.data.reporterUid == request.auth.uid
        && request.resource.data.status == "new"
        && request.resource.data.type is string
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.screen is string
        && request.resource.data.severity is string;
      allow update, delete: if isAdmin();
    }

    // Admin audit log — the `deleteUser` callable (Admin SDK, bypasses these rules)
    // writes one immutable record per destructive admin action (who deleted whom,
    // when, + the cascade counts). Admin-READABLE only; NO client may write it (the
    // function writes via the Admin SDK), so it can never be forged or tampered with
    // from a browser.
    match /admin_audit/{id} {
      allow read:  if isAdmin();
      allow write: if false;
    }
  }
}
